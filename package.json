{
  "name": "@tunnet/monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/cloud-stubs/*",
    "crates/tunnet-node-napi"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks && git config pull.ff only",
    "management:dev": "bun --env-file=.env --filter @tunnet/management dev",
    "management:start": "bun --env-file=.env --filter @tunnet/management start",
    "dash:dev": "bun --env-file=.env --filter @tunnet/dashboard dev",
    "dash:build": "bun --env-file=.env --filter @tunnet/dashboard build",
    "dash:preview": "bun --env-file=.env --filter @tunnet/dashboard preview",
    "db:generate": "bun --env-file=.env --filter @tunnet/db generate",
    "db:migrate": "bun --env-file=.env --filter @tunnet/db migrate",
    "db:studio": "bun --env-file=.env --filter @tunnet/db studio",
    "docs:dev": "bun --env-file=.env --filter @tunnet/docs dev",
    "docs:build": "bun --env-file=.env --filter @tunnet/docs build",
    "docs:preview": "bun --env-file=.env --filter @tunnet/docs preview",
    "test:sdk": "bun --env-file=.env --filter @tunnet/sdk test",
    "test": "bun --env-file=.env --filter @tunnet/sdk test",
    "test:sdk:integration": "bun --env-file=.env --filter @tunnet/sdk test:integration",
    "check": "biome check",
    "sync:private": "bun run scripts/sync-private.ts",
    "push:oss": "bun run scripts/push-oss.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.10",
    "vitepress": "^2.0.0-alpha.18"
  },
  "dependencies": {
    "ip-address": "^10.2.0",
    "zod": "^4.4.3"
  }
}
