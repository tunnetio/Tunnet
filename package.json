{
  "name": "tuntun",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/cloud-stubs/*",
    "crates/tuntun-node-napi"
  ],
  "scripts": {
    "management:dev": "bun --env-file=.env --filter @tuntun/management dev",
    "management:start": "bun --env-file=.env --filter @tuntun/management start",
    "dash:dev": "bun --env-file=.env --filter @tuntun/dashboard dev",
    "dash:build": "bun --env-file=.env --filter @tuntun/dashboard build",
    "dash:preview": "bun --env-file=.env --filter @tuntun/dashboard preview",
    "db:generate": "bun --env-file=.env --filter @tuntun/db generate",
    "db:migrate": "bun --env-file=.env --filter @tuntun/db migrate",
    "db:studio": "bun --env-file=.env --filter @tuntun/db studio",
    "docs:dev": "bun --env-file=.env --filter @tuntun/docs dev",
    "docs:build": "bun --env-file=.env --filter @tuntun/docs build",
    "docs:preview": "bun --env-file=.env --filter @tuntun/docs preview",
    "test:sdk": "bun --env-file=.env --filter @tuntun/core test",
    "test": "bun --env-file=.env --filter @tuntun/core test",
    "test:sdk:integration": "bun --env-file=.env --filter @tuntun/core test:integration",
    "check": "biome check",
    "sync:public": "bun run scripts/sync-public.ts",
    "guard:public-push": "bun run scripts/guard-public-push.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.10",
    "vitepress": "^2.0.0-alpha.18"
  },
  "dependencies": {
    "ip-address": "^10.2.0",
    "zod": "^4.4.3"
  }
}
